{% extends 'layouts/base.twig' %}

{% block header %}
	{% include 'layouts/header.twig' %}
	{% if hero.show and hero.position == 'above' %}{% include 'layouts/header/hero-newsletter.twig' %}{% endif %}
	{% include 'layouts/navbar/navbar.twig' %}
	{% if hero.show and hero.position == 'below' %}{% include 'layouts/header/hero-newsletter.twig' %}{% endif %}
{% endblock %}

{% block content %}

    <main class="content-area row newsletter-index {{main_classes}}" role="main">

		{# Widget area before featured articles #}
		{% if widgets.before_featured %}
			<div class="w-100 widget-area widget-before-featured">
				{{widgets.before_featured}}
			</div>
		{% endif %}

		{# Featured articles #}
		{% if articles.featured %}
			<div class="w-100 featured-articles template-{{config.featured.template}} {{config.featured.class}}">
				<div class="row">
					{% include "templates/featured/#{config.featured.template}.twig" with {
						'articles' 	: articles.featured,
						'config'	: config.featured
					} %}
				</div>
			</div>
		{% endif %}

		{# Widget area between featured and index articles #}
		{% if widgets.between_featured_index %}
			<div class="w-100 widget-area widget-between-featured-index">
				{{widgets.between_featured_index}}
			</div>
		{% endif %}

		{# Index articles #}
		{% if articles.index %}
			<div class="w-100 index-articles template-{{config.index.template}}
						{{config.index.class}}
						{% if config.index.categorized %} categorized {% endif %}">

				{% for category in articles.index %}
					{% if category.posts %}

						{% if category.name %}
							<h2 class="section-title" id="{{category.slug}}">{{category.name}}</h2>
						{% endif %}

						<div class="row">
							{% include "templates/index/#{config.index.template}.twig" with {
								'articles' 	: category.posts,
								'config'	: config.index
							} %}
						</div>

					{% endif %}
				{% endfor %}

			</div>
		{% else %}
			<div class="alert alert-danger d-flex my-5">
				There are currently no published articles.
			</div>
		{% endif %}

		{# Widget area after index articles #}
		{% if widgets.after_index %}
			<div class="w-100 widget-area widget-after-index">
				{{widgets.after_index}}
			</div>
		{% endif %}

    </main>

{% endblock %}