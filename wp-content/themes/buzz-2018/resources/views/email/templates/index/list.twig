{% if articles %}
	<table class="index" cellpadding="0" cellspacing="20" width="640">
		{% if title %}
			<tr>
				<td><h2 class="section-title">{{title}}</h2></td>
			</tr>
		{% endif %}

		{% for post in articles  %}
			{% set has_thumb = config.show_thumb and post.thumbnail %}

			<tr>
				<td class="index__article {% if config.text_padding %} text-padding{% endif %}" valign="top">

					<table cellpadding="0" cellspacing="0" width="600"
						class="{% if has_thumb %} has-thumb {% else %} no-thumb {% endif %}">

						{% if has_thumb %}
							<tr>
								{% set image = post.thumbnail %}
								{% set width = image.sizes['email-thumb'].width %}

								<td class="image" valign="top" width="{{width}}"
									rowspan="{% if config.more.type == 'button' %}4{% else %}3{% endif %}">
									<a href="{{ post.link }}">
										<img src="{{ image.src( 'email-thumb' ) }}" alt="{{ image.alt | default( post.title ) | escape }}">
									</a>
								</td>
							</tr>
						{% endif %}

						<tr>
							<td class="title"><h3 class="post-title"><a href="{{ post.link }}" class="title__link">{{ post.title }}</a></h3></td>
						</tr>

						<tr>
							<td class="excerpt">
								{% include 'email/partials/excerpt.twig' %}
							</td>
						</tr>

						<tr>
							<td class="link">
								{% include 'email/partials/readmore.twig' %}
							</td>
						</tr>

					</table>

				</td>
			</tr>
		{% endfor %}

	</table>
{% endif %}