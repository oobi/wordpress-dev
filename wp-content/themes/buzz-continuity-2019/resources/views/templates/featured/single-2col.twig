{% for post in articles %}

	{% if config.show_thumb %}
		{% set has_thumb = fn('has_post_thumbnail', post.id) %}
	{% endif %}

	<article class="article-tease col-12
		{% if has_thumb %} has-thumb {% else %} no-thumb {% endif %}
		{{post.classes}}">

		<div class="article-inner row">

			{# Image #}
			{% if has_thumb %}

				<div class="article-tease__image col-md-6">
					{% include 'templates/partials/thumb.twig' with {
						'post'		: post,
						'size'		: {
							'default'	: 'article',
							'large'		: 'article-large',
						}
					} only %}
				</div>

			{% endif %}

			{# Text #}
			<div class="article-tease__content col {{config.excerpt_class}}">
				<h3 class="title">
					<a href="{{ post.link }}" class="title__link">
						{{ post.title }}
					</a>
				</h3>

				{% include 'templates/partials/excerpt.twig' %}
				{% include 'templates/partials/tags.twig' %}
				{% include 'templates/partials/readmore.twig' %}
			</div>

		</div>

	</article>

{% endfor %}