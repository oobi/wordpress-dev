<div class="hero row">
	{% if post.thumbnail %}
		{% set image = post.thumbnail %}
		<picture>
			<source media="(max-width: 767px)" srcset="{{ image.src('email-hero') }}">
				<img src="{{ image.src('newsletter-hero') }}"
					class="slide__image"
					alt="{{ image.alt | default(post.title) }}"
					description="{{ image.description }}"
					style="width:100%;">
		</picture>
	{% endif %}
</div>