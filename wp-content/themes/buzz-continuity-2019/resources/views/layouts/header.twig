<header id="masthead" class="site-header row {{header_type}}-header" role="banner">
	<div class="inner">

		{% if header_type == 'image' %}

			<a href="{{ fn( 'get_home_url' ) }}" class="homelink">
				{{ header_image_large }}
				{{ header_image_small }}
			</a>

		{% else %}

			<a href="{{ fn( 'get_home_url' ) }}" class="homelink col">
				{% if header_logo %}
					<span class="logo">
						{{ header_logo }}
					</span>
				{% endif %}
				<span class="text">
					<span class="title">{{header_text_title}}</span>
					<span class="subtitle">{{header_text_subtitle}}</span>
				</span>
			</a>

		{% endif %}

		{% if widgets.header %}
			{{widgets.header}}
		{% endif %}

	</div>
</header>