<tr>
    <td id="navbar" align="center" valign="top">
        <table border="0" cellpadding="0" cellspacing="15" width="620">
            <tr>

				{# view full newsletter link #}
                <td class="view-full" align="left" width="240">
                    <a href="{{ newsletter.link }}">View Full Newsletter</a>
				</td>

				{# newsletter title and link #}
                <td class="newsletter-info" align="right">
					{% if show_nav_title or show_nav_date %}
						{% if show_nav_title %}
							{{newsletter.title}}
						{% endif %}

						{% if show_nav_title and show_nav_date %}
							&nbsp;&ndash;&nbsp;
						{% endif %}

						{% if show_nav_date %}
							{{newsletter.post_date | strftime(date_format)}}
						{% endif %}
					{% endif %}
				</td>

            </tr>
        </table>
    </td>
</tr>