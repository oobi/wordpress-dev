<div class="hero pb-8">
	{% if post.thumbnail %}
		{% set image = post.thumbnail %}
		<picture>
			<source media="(max-width: 767px)" srcset="{{ image.src('article') }}">
			<img src="{{ image.src('article-large') }}"
				class="slide__image"
				alt="{{ image.alt | default(post.title) | escape  }}"
				description="{{ image.description | escape  }}"
				style="width:100%;">
		</picture>
	{% endif %}
</div>