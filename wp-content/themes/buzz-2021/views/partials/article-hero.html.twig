{% if post.thumbnail %}
	{% set image = post.thumbnail %}
	<div class="article-hero card pb-8">
		<picture>
			<source media="(max-width: 767px)" srcset="{{ image.src('article_feature') }}">
			<img class="card-img" src="{{ image.src('article_feature') }}"
				alt="{{ image.alt | default(post.title) | escape  }}"
				description="{{ image.description | escape  }}"
				style="width:100%;">
		</picture>
	</div>
{% endif %}