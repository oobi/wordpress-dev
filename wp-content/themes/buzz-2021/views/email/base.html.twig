<!DOCTYPE html>
<html id="email">
<head>
    <meta charset="{{site.charset}}" />
    <meta name="description" content="{{site.description}}">
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {{function('wp_head')}}

     {# Kirki Styles #}
     <style id="buzz-kirki-styles">
        #email {
            font-family: {{ fonts.body.font_family }};
            font-weight: {{ fonts.body.font_weight }};
            font-size: {{ fonts.body.size }};
            line-height: {{ fonts.body.line_height }};
            letter-spacing: {{ fonts.body.letter_spacing }};
        }

        #email h1, #email h2, #email h3, #email h4, #email h5, #email h6, h1, h2, h3, h4, h5, h6 {
            font-family: {{ fonts.heading.font_family }};
            line-height: {{ fonts.heading.line_height }};
        }
    </style>
</head>

<body id="email-view">
	<table id="email-container" border="0" cellpadding="0" cellspacing="0" align="center" width="640">

        {# Include the header #}
        {% include 'email/header.html.twig' %}

        {% include 'email/body.html.twig' %}

        {% include 'email/footer.html.twig' %}

	</table><!-- #wrapper -->
</body>
</html>