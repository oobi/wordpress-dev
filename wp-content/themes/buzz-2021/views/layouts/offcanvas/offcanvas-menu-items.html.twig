{% if newslettter_nav %}

	{% if not newsletter %}
		{# home #}
		<li class="nav-item menu-item newsletter-archive">
			<a class="nav-link" href="{{site.link}}">Latest Issue</a>
		</li>
	{% endif %}

	{# archive #}
	<li class="nav-item menu-item newsletter-archive">
		<a class="nav-link" href="{{ fn('get_post_type_archive_link', 'newsletter') }}">Archive</a>
	</li>

	{% if newsletter and addons.print_view %}
		{# print #}
		<li class="d-none d-lg-block nav-item menu-item print">
			<a class="nav-link" href="{{ fn('ff_get_print_url', newsletter.id) }}">Print</a>
		</li>
	{% endif %}

{% endif %}

{# menu (optional) #}
{% if menu %}
	{% for item in menu %}

		<li class="nav-item {{ item.classes | join(' ') }} {% if item.children %}dropdown{% endif %}">
			<a class="nav-link {% if item.children %}dropdown-toggle{% endif %}"
				id="page-{{ item.id }}"
				
				{% if item.children %}
					data-bs-toggle="collapse"
					aria-expanded="false"
					aria-controls="collapse-{{ item.id }}"
					role="button"
					href="#collapse-{{ item.id }}"
				{% else %}
					href="{{ item.link }}"
				{% endif %} 
				
				{% if item.target %}target="{{item.target}}"{% endif %}>

				{% if item.current %}
					<span class="sr-only">(current)</span>
				{% endif %}
				{{ item.title }}

			</a>

			{% if item.children %}
				<ul class="collapse multi-collapse navbar-nav" id="collapse-{{ item.id }}">
					{% for child in item.children %}
						<li class="nav-item {{ child.classes | join(' ') }}">
							<a class="nav-link" href="{{ child.link }}" {% if child.target %}target="{{child.target}}"{% endif %}>
								{% if child.current %}
									<span class="sr-only">(current)</span>
								{% endif %}
								{{ child.title }}
							</a>
						</li>
					{% endfor %}
				</ul>
			{% endif %}
		</li>

	{% endfor %}
{% endif %}