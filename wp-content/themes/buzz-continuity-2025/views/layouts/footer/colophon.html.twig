<section class="colophon {{ footer.colophon_class | default('py-2 px-8')}}">
	<div class="container">
		<div
			class="row">

			{# COPYRIGHT #}
			<div class="col-md-6 d-sm-flex align-items-center">
				<div class="copyright text-center text-md-start text-primary-hover text-muted">
					&copy;
					{{ "now"|date('Y') }}
					{{ footer.copyright }}
				</div>
			</div>

			{# Footer Menu #}
			<div class="col-md-6 d-sm-flex align-items-center justify-content-center justify-content-md-end">

					{# Footer menu #}
					{% if menus.footer.get_items %}
						<ul class="nav text-primary-hover text-center text-sm-end justify-content-center justify-content-center mt-3 mt-md-0">
							{% for item in menus.footer.get_items %}
								<li class="{{ item.classes | join(' ') }} nav-item">
									<a class="nav-link" target="{{ item.target }}" href="{{ item.link }}">
										{{ item.title }}
									</a>
								</li>
							{% endfor %}
						</ul>
					{% endif %}

					{# CREDIT #}
					<div class="d-flex align-items-center justify-content-center position-relative site-credit ps-sm-4 mt-3 mt-md-0 text-center">
						<a href="http://www.thebuzz.net.au" target="_blank" rel="link" class="fancy-link stretched-link">
							Powered by
							<span class="d-none">The Buzz</span>
						</a>
						<span class="site-credit__logo">{{ source('assets/images/buzz-icon.svg') }}</span>
					</div>

			</div>

		</div>
	</div>
</section>
