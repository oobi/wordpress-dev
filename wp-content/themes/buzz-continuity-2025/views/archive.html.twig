{% extends 'layouts/base.html.twig' %}

{% block content %}

	<div class="content-area row">
		<main class="main-content col" role="main">

			<article class="post-content">

				<h1>{{title}}</h1>

				{% if posts %}
					<div class="row">
						{% for post in posts %}

							<article class="article-tease article-tease--column mb-5 col-md-3
								{{post.classes}}">

								{% set has_thumb = fn('has_post_thumbnail', post.id) %}
								{% if has_thumb %}
									{% set image = post.thumbnail %}
									<div class="article-tease__image mb-3">
										<a href="{{ post.link }}">
											<picture>
												<img src="{{ image.src('article') }}"
													class="slide__image"
													alt="{{ image.alt | default(post.title) | escape  }}"
													title="{{ image.title | default(post.title) | escape  }}"
													description="{{ image.description | escape  }}"
													style="width:100%;">
											</picture>
										</a>
									</div>

								{% endif %}

								<div class="article-tease__content {% if has_thumb %} has-thumb {% else %} no-thumb {% endif %}">
									<h4 class="title">
										<a href="{{ post.link }}" class="title__link">{{ post.title }}</a>
									</h4>
									<p class="date">{{post.post_date | strftime(date_format)}}</p>
									<a class="btn" href="{{ post.link }}">Read more</a>
								</div>

							</article>

						{% endfor %}
					</div>
					{% include 'partials/pagination.html.twig' %}
				{% endif %}

			</article>

		</main>
	</div>

{% endblock %}