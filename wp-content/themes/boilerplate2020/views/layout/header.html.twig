{#
    For Hover navigation:
    {% import 'layout/navigation-macro-hover.html.twig' as nav %}

    For Click and Stick navigation:
    {% import 'layout/navigation-macro-click.html.twig' as nav %}
#}
{% import 'layout/navigation-macro-click.html.twig' as nav %}

{# Add the 'hover-nav' class here if you want the dropdown menus to display on hover instead of on click. #}
<header class="site-header">
    {# BEGIN Utilities #}
    <section class="bg-dark text-white">
        <div class="container">
            <div class="d-flex justify-content-end py-2">
                {% if menus.utility.get_items %}
                    <nav class="navbar d-flex navbar-expand navbar-dark">
                        <ul class="navbar-nav me-auto">
                            {{ nav.render(menus.utility.get_items) }}
                        </ul>
                    </nav>
                {% else %}
                    <span class="nav-text">Please set up the utility menu</span>
                {% endif %}
            </div>
        </div>
    </section>
    {# END Utilities #}

    {# BEGIN Navigation #}
    <nav class="navbar navbar-expand-lg navbar-light bg-light primary-navigation">
        <div class="container">

            {# BEGIN Logo #}
            <a class="navbar-brand" href="{{ site.link }}">
                <img style="width:3rem;" src="{{ site.theme.link }}/assets/images/logo.svg" alt="{{ site.name }}">
            </a>
            {# END Logo #}

            {# BEGIN Hamburber Button #}
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarsExample07" aria-controls="navbarsExample07" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            {# END Hamburber Button #}

            {# BEGIN Menu #}
            <div class="collapse navbar-collapse" id="primaryNavigation">
                <ul class="navbar-nav me-auto">
                    {{ nav.render(menus.primary.get_items) }}
                </ul>
            </div>
            {# END Menu #}

        </div>
    </nav>
    {# END Navigation #}
</header>